rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can be read by anyone, but only the user themselves can update their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth.uid == userId;

      // Contacts subcollection
      // A user can only list/read/create contacts within their own document.
      match /contacts/{contactId} {
        allow read, list: if request.auth.uid == userId;
        allow create, delete: if request.auth.uid == userId;
      }
    }
    
    // Friend requests
    match /friendRequests/{requestId} {
      // Anyone can create (send) a friend request.
      allow create: if request.auth != null;
      
      // Only the sender or receiver can read a specific request.
      allow get: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
      
      // Only the receiver can update a request (to accept/decline it).
      allow update: if request.auth.uid == resource.data.to;
      
      // A user can only query for requests sent *to* them.
      // This rule matches the query in src/app/contacts/page.tsx
      allow list: if request.auth.uid == request.query.where.to && request.query.where.status == 'pending';
    }

    // Chat rooms and their messages
    match /chats/{chatId} {
      // A user can only access a chat room if they are a participant.
      allow get, list: if request.auth.uid in resource.data.participants;
      allow create: if request.auth.uid in request.resource.data.participants;
      
      // This rule allows the query in src/app/chat/page.tsx to work.
      // It validates that the user is querying for chats where they are a participant.
      // Note: Firestore requires a composite index for this query.
      allow list: if request.auth.uid in request.query.where.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Users can only read/write messages in chats they are a part of.
        allow list, get: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) && request.auth.uid == request.resource.data.senderId;
      }
    }

    // Call documents for WebRTC signaling
    match /calls/{callId} {
      // A user can access a call document only if they are a participant.
      allow get, update: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      allow create: if request.auth.uid in request.resource.data.participants;
      allow delete: if request.auth.uid in resource.data.participants;

      // ICE candidates subcollections
      match /{collectionId}/{candidateId} {
        // Participants can add and read ICE candidates for signaling.
        allow list, create: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
        allow delete: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
    
    // Call invitations for notifying users of incoming calls.
    match /callInvitations/{invitationId} {
        allow create: if request.auth != null && request.auth.uid == request.resource.data.caller.id;
        
        // A user can get a specific invitation if they are the receiver.
        allow get: if request.auth.uid == resource.data.receiverId;
        
        // A user can update an invitation if they are the receiver (to answer/decline).
        allow update: if request.auth.uid == resource.data.receiverId;
        
        // A user can delete an invitation if they are the receiver (e.g., after declining).
        allow delete: if request.auth.uid == resource.data.receiverId;
        
        // This rule matches the onIncomingCall query in src/lib/firebase.ts
        allow list: if request.auth.uid == request.query.where.receiverId && request.query.where.status == 'ringing';
    }
  }
}
