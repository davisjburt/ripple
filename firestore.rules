
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users: Can read their own user doc, other users can only see limited profile data.
    // Cannot be listed or written to by clients except during signup.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts: Only the owner of the contacts subcollection can read/write to it.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend Requests:
    // - Can create a request.
    // - Can read/update a request only if they are the recipient ('to').
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.uid == resource.data.to;
    }

    // Chats & Messages:
    // - Users can query the 'chats' collection if their UID is in the 'participants' array.
    // - Users can read/write messages in a chat they are a participant in.
    match /chats/{chatId} {
      allow read, list: if request.auth.uid in resource.data.participants;
      allow create: if request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      }
    }
  }
}
