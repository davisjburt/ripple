rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by any authenticated user, but only the user themselves can update their own document.
    // Writes are only allowed for creation (e.g., during signup).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == userId;

      // A user can only access their own contacts list.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests have more complex rules.
    match /friendRequests/{requestId} {
      // Allow read if the user is either the sender or the receiver of the request.
      allow read: if request.auth != null && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      // Allow creation by any authenticated user.
      allow create: if request.auth != null;
      // Allow update (accept/decline) only by the user who received the request.
      allow update: if request.auth != null && request.auth.uid == resource.data.to;
    }

    // Chat documents can be read or written to only by the participants of the chat.
    // The query to list chats is secured by a rule on the collection itself.
    match /chats/{chatId} {
        allow list: if request.auth != null && request.auth.uid in request.query.where.participants;
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;

        // Messages can only be read or written by participants of the parent chat.
        match /messages/{messageId} {
            allow read, write: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        }
    }
  }
}