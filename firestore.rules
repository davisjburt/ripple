
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    // - Anyone can create a user document (needed for sign-up).
    // - Authenticated users can read other user profiles (to find contacts).
    // - Users can only update or delete their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Contacts (sub-collection of users)
    // - A user can only manage their own contacts list.
    match /users/{userId}/contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend Requests
    // - Authenticated users can create requests.
    // - You can only read requests sent to you.
    // - You can only accept/decline requests sent to you.
    // - The sender can cancel their own request.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
      allow list: if request.auth != null && request.query.where.to == request.auth.uid;
    }

    // Chats
    // - You can only read/write messages in a chat if you are a participant.
    // - You can only list chats where you are a participant.
    match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
        
        // This rule allows the query in src/app/chat/page.tsx
        allow list: if request.auth != null && request.query.where.participants.includes(request.auth.uid);

        match /messages/{messageId} {
            allow read, write: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        }
    }
  }
}
