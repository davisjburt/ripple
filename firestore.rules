
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Users can be read by any authenticated user, but only queried by email.
    // This allows for adding contacts by email.
    // User data can only be written by the user themselves.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts are private to each user
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests have specific rules for creation and updates.
    match /friendRequests/{requestId} {
      // Allow user to read requests sent to them
      allow get: if request.auth != null && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      
      // Allow a user to see all requests sent to them.
      // This is what enables the real-time listener on the contacts page.
      allow list: if request.auth != null && request.query.get("to") == request.auth.uid;
      
      // Allow creating a request if the sender is the logged-in user.
      allow create: if request.auth.uid == request.resource.data.from;
      
      // Allow updating (accepting/declining) a request if the receiver is the logged-in user.
      allow update: if request.auth.uid == resource.data.to;
      
      // Allow deleting a request if you are the sender or receiver
      allow delete: if request.auth != null && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
    }

    // Chat messages can only be read/written by participants in the chat.
    // The chat room ID is a combination of the two user IDs, sorted.
    match /chats/{chatRoomId}/{messageId} {
       allow read, write: if request.auth != null && request.auth.uid in chatRoomId.split('_');
    }
  }
}
