
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Can read/write their own user document. Can read other users' public profiles.
    match /users/{userId} {
      allow read;
      allow write: if request.auth.uid == userId;

      // Contacts subcollection: Can read/write their own contacts.
      match /contacts/{contactId} {
         allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend Requests: Can create requests. Can update/delete requests where they are the recipient.
    match /friendRequests/{requestId} {
      allow read: if request.auth.uid == resource.data.to || request.auth.uid == resource.data.from;
      allow create: if request.auth.uid == request.resource.data.from;
      allow update, delete: if request.auth.uid == resource.data.to;
    }
    
    // Chat rooms: Can read/write messages in rooms they are a participant of.
    match /chats/{chatId} {
      allow read, write: if request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
    
    // Call invitations: Can create/update/delete their own invitations.
    match /callInvitations/{invitationId} {
      allow read, write, delete: if request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id;
      allow create: if request.auth.uid != null;
    }
    
    // Calls: Can read/write call documents they are a participant in.
    match /calls/{callId} {
       allow read, write: if request.auth.uid in resource.data.participants;

      // ICE Candidates subcollections
      match /{candidatesCollection}/{candidateId} {
         allow read, write: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
  }
}
