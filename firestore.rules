rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    // - Anyone can create a user profile (on signup).
    // - Users can only read/update/delete their own profile.
    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if request.auth.uid != null;

      // Contacts are a subcollection of users
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend Requests
    // - Authenticated users can create requests.
    // - Only the sender or receiver can read/update the request.
    match /friendRequests/{requestId} {
        allow read, update: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
        allow create: if request.auth.uid != null;
    }

    // Chat rooms
    // - Only participants of the chat can read/write messages.
    match /chats/{chatId}/{messages=**} {
       allow read, write: if request.auth.uid in resource.data.participants;
    }
    
    // Call Invitations
    // - Authenticated users can create invitations.
    // - Users can only read invitations where they are the receiver.
    match /callInvitations/{invitationId} {
      allow create: if request.auth.uid != null;
      allow read, update, delete: if request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id;
    }

    // Calls
    // - Only participants can create, read, or write to a call document.
     match /calls/{callId} {
      allow create, read, write: if request.auth.uid in resource.data.participants;

      // ICE candidates subcollection
      match /{candidates}/{candidateId} {
        allow create, read, write: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
  }
}
