rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read public user data, but only write to their own document.
    match /users/{userId} {
      allow get: if request.auth != null;
      allow update: if request.auth.uid == userId;

      // Users can get and list contacts from their own 'contacts' subcollection.
      match /contacts/{contactId} {
        allow get: if request.auth.uid == userId;
        allow list: if request.auth.uid == userId;
      }
    }
    
    // Friend Requests:
    // Users can create requests.
    // Users can only query for requests sent *to* them that are *pending*.
    // Users can update/delete requests sent to them.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow get, update, delete: if resource.data.to == request.auth.uid;
      allow list: if request.auth.uid == request.query.where.to && request.query.where.status == 'pending';
    }

    // Chats & Messages:
    // Users can only access chats they are a participant in.
    match /chats/{chatId} {
      allow get, list: if request.auth.uid in resource.data.participants;
      
      // For querying the collection, the query must include the user's UID.
      // This is a special rule for collection group queries vs document reads.
      allow list: if request.auth.uid in request.query.where.participants;

      // Users can read/write messages in chats they are a participant of.
      match /messages/{messageId} {
        allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Call Invitations:
    // Authenticated users can create invitations.
    // Users can only read/update/delete invitations sent to them.
    // Users can only query for invitations where they are the receiver and status is 'ringing'.
    match /callInvitations/{invitationId} {
      allow create: if request.auth != null;
      allow get, update, delete: if resource.data.receiverId == request.auth.uid;
      allow list: if request.auth.uid == request.query.where.receiverId && request.query.where.status == 'ringing';
    }

    // Calls & Signaling Candidates:
    // Users can only access call documents they are a participant in.
    match /calls/{callId} {
      allow read, write, delete: if request.auth.uid in resource.data.participants;
      
      // Users can read/write candidates if they are a participant in the parent call document.
      match /{collectionId}/{candidateId} {
        allow read, write, delete: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
  }
}
