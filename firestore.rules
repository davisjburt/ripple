
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read public info on any user profile.
    // A user can only update their own profile.
    // A user can create their own profile document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth.uid == userId;
    }

    // Users can only manage their own contacts subcollection.
    match /users/{userId}/contacts/{contactId} {
      allow read, write, delete: if request.auth.uid == userId;
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read by the sender or receiver.
    // They can only be updated (accepted/declined) by the receiver.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.uid == resource.data.to || request.auth.uid == resource.data.from;
    }

    // Chat documents can be read or written to by participants only.
    match /chats/{chatId} {
      allow get, list, create, update, delete: if request.auth.uid in resource.data.participants;
    }

    // Messages can be read or written by chat participants.
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
    }
  }
}
