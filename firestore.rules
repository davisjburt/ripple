rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can read their own user document and any other user's public profile info.
    // Users can only create their own user document.
    // Users can only update their own document.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isAuthenticated() && isOwner(userId);
      
      // Contacts subcollection rules
      // Users can only read and write to their own contacts list.
      match /contacts/{contactId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // Friend requests
    // Users can create a friend request.
    // Users can read requests sent to them or by them.
    // Users can update a request (to accept/decline) only if it was sent to them.
    match /friendRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.to == request.auth.uid;
    }

    // Chats collection rules
    match /chats/{chatId} {
      // A user can list (query) chats if their UID is in the participants array.
      // This is the key rule to fix the main "permission-denied" error on the chat list page.
      allow list: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // A user can get, create, or update a chat document if they are a participant.
      allow get, create, update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Messages subcollection rules
      // A user can read, list, and create messages in a chat if they are a participant of that chat.
      match /messages/{messageId} {
        allow list, read: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0] == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1] == request.auth.uid;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && (get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0] == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1] == request.auth.uid);
      }
    }
  }
}
