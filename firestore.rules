rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can be read by any authenticated user, but only the owner can write/update their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts are private to each user
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests have specific rules for creation and updates.
    match /friendRequests/{requestId} {
      // Anyone can create a request (send one).
      allow create: if request.auth != null;
      // You can read a request if you sent it or received it.
      allow read: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
      // You can only update/delete a request if you are the recipient.
      allow update, delete: if request.auth.uid == resource.data.to;
    }
    
    // Chat messages can only be read/written by participants of the chat.
    match /chats/{chatId} {
        allow read, write: if request.auth.uid in resource.data.participants;
        
        match /messages/{messageId} {
            allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
    }
  }
}
