
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // USERS
    // Users can read their own document and other users' public profiles
    // Users can only create their own user document
    // Users can only update their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      
      // Contacts subcollection
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // FRIEND REQUESTS
    // Users can create requests
    // Users can read/update requests where they are the sender or receiver
    match /friendRequests/{requestId} {
      allow create: if request.auth.uid == request.resource.data.from;
      allow read, update: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
    }
    
    // CHATS
    // Users can read/write chat rooms they are a participant in
    match /chats/{chatId} {
        allow read, write: if request.auth.uid in resource.data.participants;
        
        // Messages subcollection
        match /messages/{messageId} {
             allow read: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
             allow create: if request.auth.uid == request.resource.data.senderId && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
    }

    // CALLS
    // Only participants can access a call document
    match /calls/{callId} {
      allow read, write, create: if request.auth.uid in request.resource.data.participants;
      
      // ICE candidates
       match /callerCandidates/{candidateId} {
        allow read, write: if exists(/databases/$(database)/documents/calls/$(callId)) && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
      match /receiverCandidates/{candidateId} {
        allow read, write: if exists(/databases/$(database)/documents/calls/$(callId)) && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
    
    // CALL INVITATIONS
    // Authenticated users can create invitations
    // A user can get a specific invitation if they are the receiver
    // A user can list invitations only if they are querying by their own receiverId
    match /callInvitations/{invitationId} {
      allow create: if request.auth != null;
      allow get: if request.auth.uid == resource.data.receiverId;
      allow list: if request.auth.uid == request.query.where.receiverId;
      allow update, delete: if request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id;
    }
  }
}
