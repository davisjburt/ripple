
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can read their own profile, and any authenticated user can view others' basic info.
    // Users can only create and update their own profile.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
    }
    
    // Users can only manage their own contacts subcollection
    match /users/{userId}/contacts/{contactId} {
        allow read, write, delete: if isOwner(userId);
    }
    
    // Friend Requests
    match /friendRequests/{requestId} {
        // Allow creating a request if authenticated
        allow create: if isAuthenticated();
        // Allow reading if you are the sender or receiver
        allow read: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
        // Allow updating (accept/decline) only by the receiver
        allow update: if isAuthenticated() && request.auth.uid == resource.data.to;
    }

    // Chats
    match /chats/{chatId} {
        // Allow reading/listing of chat rooms if the user is a participant
        allow get, list: if isAuthenticated() && request.auth.uid in resource.data.participants;
        
        // Allow users to read messages only if they are a participant of the chat
        match /messages/{messageId} {
            allow read, create: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        }
    }
  }
}
