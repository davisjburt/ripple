
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can be looked up by any authenticated user for creating contacts/requests
    // but can only write to their own user document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Users can read/write to their own contacts subcollection.
    match /users/{userId}/contacts/{contactId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read or updated by the sender or the receiver.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
    }

    // A user can list chats they are a part of.
    // A user can get/read/write a chat document if they are a participant.
    match /chats/{chatId} {
      allow list: if request.auth.uid in request.query.where.participants;
      allow read, write: if request.auth.uid in resource.data.participants;

        // Messages can only be read/written by participants of the parent chat room.
        match /messages/{messageId} {
            allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
    }
  }
}
