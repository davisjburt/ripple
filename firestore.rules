
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Users Collection ---
    // Users can read any profile (to find contacts)
    // Users can only write to their own document
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // Contacts subcollection
      match /contacts/{contactId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // --- Friend Requests Collection ---
    // Can only be created by the sender
    // Can only be read/updated by sender or receiver
    match /friendRequests/{requestId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.from;
      allow read, update, delete: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }
    
    // --- Chats Collection ---
    // Can only be read/written by participants
    // This rule also covers listing/querying chats
    match /chats/{chatId} {
      allow read, write, create: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow list: if isAuthenticated() && request.auth.uid == request.query.where.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Inherits parent's permissions: only participants can access messages
        allow read, write, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // --- Calls & Invitations ---
    // Rules for video call signaling
    
    match /calls/{callId} {
        // Only participants can create, read, or write to a call document
        allow read, write, create, delete: if isAuthenticated() && request.auth.uid in resource.data.participants;

        // The ICE candidate subcollections need to be writable by participants
        match /{subcollection=**} {
            allow read, write, create, delete: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
        }
    }

    match /callInvitations/{invitationId} {
        // Anyone authenticated can create an invitation (start a call)
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.caller.id;
      
        // The query in onIncomingCall filters by receiverId. This rule validates that query.
      allow list: if isAuthenticated() && request.auth.uid == request.query.where.receiverId;
      
      // Allow direct reads, updates, and deletes only by the caller or receiver
        allow get, update, delete: if isAuthenticated() && (request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id);
    }
  }
}
