rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own user document and other users' basic info for contacts.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Users can only read/write their own contacts.
    match /users/{userId}/contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
    }

    // Rules for friend requests
    match /friendRequests/{requestId} {
      // A user can create a request if they are the sender.
      allow create: if request.auth.uid == request.resource.data.from;

      // A user can read a request if they are the sender or receiver.
      allow read: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;

      // A user can update (accept/decline) a request only if they are the receiver.
      allow update: if request.auth.uid == resource.data.to;
      
      // Nobody can delete requests for now to keep a record.
      allow delete: if false;
    }

    // Rules for chat rooms
    match /chats/{chatId} {
      // A user can list chats they are a participant in.
      allow list: if request.auth != null && request.query.where.size() > 0 && request.query.where[0].field == 'participants' && request.query.where[0].op == 'array-contains' && request.query.where[0].value == request.auth.uid;
      
      // A user can get a specific chat document if they are a participant.
      allow get: if request.auth.uid in resource.data.participants;

      // A user can create a chat if they are one of the participants.
      allow create: if request.auth.uid in request.resource.data.participants;

      // A user can update a chat (e.g., user info) if they are a participant.
      allow update: if request.auth.uid in resource.data.participants;
    }

    // Rules for messages within a chat
    match /chats/{chatId}/messages/{messageId} {
      // A user can read messages in a chat they are a participant of.
      // This is checked by getting the parent chat document.
      allow read, list: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      
      // A user can create a message if they are a participant and the sender.
      allow create: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) && request.auth.uid == request.resource.data.senderId;
    }
  }
}
