
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own document and other public user profiles.
    // Users can update their own document.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      
      // A user can list and read the contacts within their own contacts subcollection.
      match /contacts/{contactId} {
        allow read: if request.auth.uid == userId;
      }
    }

    // Chat rooms can only be read by participants.
    // Messages can be read by participants and created by the sender.
    match /chats/{chatId} {
      allow read: if request.auth.uid in resource.data.participants;
      allow create: if request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth.uid == request.resource.data.senderId && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
    
    // Friend requests can be created by any authenticated user.
    // They can only be read or updated by the person who received the request.
    match /friendRequests/{requestId} {
      allow create: if request.auth.uid != null;
      allow read, update: if request.auth.uid == resource.data.to;
    }

    // Call invitations can be created by any authenticated user.
    // They can be read or updated by the receiver, and deleted by either participant.
    match /callInvitations/{invitationId} {
        allow create: if request.auth.uid != null;
        allow read, update: if request.auth.uid == resource.data.receiverId;
        allow delete: if request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id;
    }

    // Call documents can be created by any authenticated user.
    // They can only be read or updated by participants.
    match /calls/{callId} {
      allow create: if request.auth.uid != null;
      allow get, update, delete: if request.auth.uid in resource.data.participants;
      
      // ICE candidates for WebRTC can be created, read, and deleted by call participants.
      match /{candidatesCollection=**} {
         allow read, write, delete: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
  }
}
