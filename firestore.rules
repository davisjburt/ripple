rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Can only read/write their own data. Anyone can read basic user info.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts subcollection: Can only be managed by the parent user.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend Requests:
    // - Can create if they are the sender.
    // - Can read if they are the sender or receiver.
    // - Can update (accept/decline) if they are the receiver.
    match /friendRequests/{requestId} {
      allow create: if request.auth.uid == request.resource.data.from;
      allow read, update: if request.auth.uid == resource.data.to || request.auth.uid == resource.data.from;
    }

    // Chats:
    // - Can read/write if they are a participant in the chat.
    match /chats/{chatId} {
      allow get, list: if request.auth.uid in resource.data.participants;

      // Messages subcollection:
      // - Can read/create if they are a participant in the parent chat.
      match /messages/{messageId} {
        allow read, create: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      }
    }
    
    // Calls:
    // - Allow create if the caller is the authenticated user.
    // - Allow read/update if the receiver is the authenticated user.
    // - Allow delete if the caller or receiver is the authenticated user.
    match /calls/{callId} {
      allow create: if request.auth.uid == request.resource.data.caller.id;
      allow read, update: if request.auth.uid == resource.data.receiverId;
      allow delete: if request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id;
    }
  }
}
