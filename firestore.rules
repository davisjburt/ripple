rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by anyone, but only the user can write to their own document.
    // This allows for looking up users by email for friend requests.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // A user can only access their own contacts subcollection.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests can only be created by authenticated users.
    // They can only be read or updated by the user who received the request.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.uid == resource.data.to;
    }

    // Chat rooms can be created by anyone authenticated.
    // A user can query for their own chat rooms ('list').
    // A user can read a specific chat room document if they are a participant ('get').
    match /chats/{chatId} {
      allow create: if request.auth != null;
      allow list: if request.auth.uid in resource.data.participants;
      allow get: if request.auth.uid in resource.data.participants;

      // Messages can be read and written only by participants of the chat.
      match /messages/{messageId} {
        allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
