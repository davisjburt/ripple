
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get a user document
    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can create their own user document during signup
      allow create: if isSignedIn();
      
      // Users can only read their own document
      // Users can be read by others if they are searching by email for a friend request
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        (resource.data.email == request.query.where.email)
      );

      // Users can only update their own document
      allow update: if isSignedIn() && request.auth.uid == userId;

      // Disallow deleting user documents
      allow delete: if false;

      // Contacts subcollection
      match /contacts/{contactId} {
         // Only the user can manage their own contacts
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Friend Requests collection
    match /friendRequests/{requestId} {
      // Authenticated users can create friend requests
      allow create: if isSignedIn();
      
      // Users can read requests sent to them
      allow read: if isSignedIn() && resource.data.to == request.auth.uid;
      
      // Users can update requests sent to them (to accept/decline)
      allow update: if isSignedIn() && resource.data.to == request.auth.uid;
      
      allow delete: if false;
    }

    // Chats collection
    match /chats/{chatId} {
      // Allow reading/querying a list of chats if the user is a participant
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Allow reading a single chat document if the user is a participant
      allow get: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Allow reading and writing messages only if the user is a participant of the parent chat room
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
