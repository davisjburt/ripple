
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by any authenticated user, but only the user can write to their own document.
    // This allows for searching for users by email to send friend requests.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts are private to each user.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read if the request is to or from the current user.
    // They can only be updated (accepted/declined) by the recipient.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.uid == resource.data.to || request.auth.uid == resource.data.from;
    }

    // A user can list chats they are a participant in.
    match /chats/{chatId} {
      allow read, write: if request.auth.uid in resource.data.participants;

      // Messages can be read or written only by participants of the chat.
      match /messages/{messageId} {
        allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
