
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by anyone (for profile lookups) but only written by the user themselves.
    match /users/{userId} {
      allow read;
      allow write: if request.auth.uid == userId;

      // Contacts are a private subcollection. Only the owner can read/write their own contacts.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests have specific rules for creation and updates.
    match /friendRequests/{requestId} {
      // Anyone can create a friend request (send one).
      allow create: if request.auth != null;
      // Only the recipient of a request can update it (to accept/decline).
      allow update: if request.auth.uid == resource.data.to;
      // Only the sender or receiver can read a specific request.
      allow get: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
      // Users can only query for requests sent to them.
      allow list: if request.auth.uid == request.query.where.to;
    }

    // Chat rooms and their messages have the most specific rules.
    match /chats/{chatId} {
      // A user can query for a list of chats if their UID is in the 'participants' array.
      // This is the rule that allows the main chat list to load.
      allow list: if request.auth.uid in request.query.where.participants;

      // A user can get (read) a specific chat document if they are a participant.
      // This was the missing rule. Both `get` and `list` are needed.
      allow get: if request.auth.uid in resource.data.participants;

      // A user can create a chat if they are one of the participants.
      allow create: if request.auth.uid in request.resource.data.participants;
      
      // Messages can be read or created only by participants of the parent chat room.
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
