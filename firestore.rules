
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by any authenticated user, but only created or updated by the user themselves.
    // This allows users to look up other users by email to send friend requests.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth.uid == userId;

      // Contacts are private to each user.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests have specific rules for creation and access.
    match /friendRequests/{requestId} {
      // Allow creation if the sender is the authenticated user.
      allow create: if request.auth.uid == request.resource.data.from;

      // Allow reading only if the user is the sender or the receiver.
      allow read: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;

      // Allow updating (accepting/declining) only by the receiver.
      allow update: if request.auth.uid == resource.data.to;

      // Allow deleting only by the sender or receiver.
      allow delete: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
    }

    // Chat messages can only be accessed by the participants.
    match /chats/{chatRoomId}/messages/{messageId} {
      allow read, write: if request.auth.uid in chatRoomId.split('_');
    }
  }
}
