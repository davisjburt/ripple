
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users Collection
    // - Allow signed-in users to read the list of users for adding contacts.
    // - Users can only create their own user doc.
    // - Users can only update their own doc.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isUser(userId);
      allow update: if isUser(userId);
      
      // Contacts Sub-collection
      // - A user can only manage their own contacts list.
      match /contacts/{contactId} {
        allow read, write: if isUser(userId);
      }
    }

    // Friend Requests Collection
    // - Users can create requests.
    // - Users can read requests sent to or from them.
    // - Users can update requests sent to them (to accept/decline).
    match /friendRequests/{requestId} {
       allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
       allow read: if isSignedIn() && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
       allow update: if isSignedIn() && resource.data.to == request.auth.uid;
       allow delete: if false; // Or specific logic if needed
    }

    // Chats Collection
    // - Users can only list/read chats they are a part of.
    // - Users can only create chats where they are a participant.
    match /chats/{chatId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow read, create: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      // Messages Sub-collection
      // - Participants of a chat can read and write messages.
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0] == request.auth.uid || 
                              get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1] == request.auth.uid;
      }
    }
  }
}
