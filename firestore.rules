rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own user document and public data of others.
    // They can only create their own user document, and update their own.
    match /users/{userId} {
      allow read;
      allow create, update: if request.auth.uid == userId;

      // A user can list their own contacts.
      match /contacts/{contactId} {
        allow list: if request.auth.uid == userId;
      }
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read/listed by the intended recipient.
    // They can only be updated by the recipient.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow list: if request.auth.uid == request.query.where.to && request.query.where.status == 'pending';
      allow get, update: if request.auth.uid == resource.data.to;
    }

    // Chats can only be accessed by participants.
    match /chats/{chatId} {
      allow get, list: if request.auth.uid in resource.data.participants;
      
      // Messages within a chat can be read by participants and created by participants.
      match /messages/{messageId} {
        allow list, get: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if request.auth.uid == request.resource.data.senderId &&
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      }
    }

    // Call invitations can be created by anyone authenticated.
    // They can only be listed/read by the intended receiver.
    match /callInvitations/{invitationId} {
        allow create: if request.auth != null;
        allow get, update, delete: if request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.caller.id;
        allow list: if request.auth.uid == request.query.where.receiverId;
    }
    
    // Call documents for WebRTC signaling.
    match /calls/{callId} {
        allow get, update: if request.auth.uid in resource.data.participants;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid in resource.data.participants;
        
        // Candidates can be read/written by participants of the call.
        match /{collectionId}/{candidateId} {
            allow read, write: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
        }
    }
  }
}
