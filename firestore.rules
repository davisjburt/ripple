
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // USERS
    // Users can read their own profile, and can only update their own profile.
    // Users can be read by others only if they are contacts.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // CONTACTS Subcollection
      // Users can read/write to their own contacts list.
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // FRIEND REQUESTS
    // Users can create friend requests.
    // Users can read/update requests sent to them.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && request.resource.data.to == request.auth.uid;
      // Allow sender to read the request status as well
      allow read: if request.auth != null && request.resource.data.from == request.auth.uid;
    }
    
    // CHATS
    // Users can query for chats they are a part of.
    // Users can read/write to chats they are a part of.
    match /chats/{chatId} {
      allow list: if request.auth != null && request.auth.uid in resource.data.participants;
      allow get, update, write: if request.auth != null && request.auth.uid in resource.data.participants;

      // MESSAGES Subcollection
      // Users can read/write messages in chats they are a part of.
      match /messages/{messageId} {
        allow read, write, create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      }
    }
  }
}
