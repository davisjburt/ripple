
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read any profile, but only write to their own.
    match /users/{userId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth.uid == userId;

      // A user can only read/write to their own contacts list.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // A user can only read a chat if they are a participant.
    match /chats/{chatId} {
      allow read, update, create: if request.auth.uid in resource.data.participants;

      // Messages can only be read/written by chat participants.
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Friend requests can be created by anyone, but only read/updated by the recipient.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.uid == resource.data.to;
    }

    // Call documents can be created by anyone, but only read/updated by participants.
    match /calls/{callId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth.uid in resource.data.participants;

      // Signaling candidates can be created, read, and deleted by call participants.
      match /callerCandidates/{candidateId} {
        allow read, create, delete: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
      match /receiverCandidates/{candidateId} {
        allow read, create, delete: if request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }

    // Call invitations can be created by anyone, but only read/updated/deleted by the recipient.
    match /callInvitations/{invitationId} {
       allow create: if request.auth != null;
       allow read, update, delete: if request.auth.uid == resource.data.receiverId;
    }

  }
}
