
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by any authenticated user for finding contacts.
    // Users can only write to their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // A user can only access their own contacts sub-collection.
    match /users/{userId}/contacts/{contactId} {
       allow read, write: if request.auth.uid == userId;
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read if the user is the recipient of the request.
    // They can be updated (accepted/declined) by the recipient.
    match /friendRequests/{requestId} {
      allow create: if request.auth.uid == request.resource.data.from;
      allow read: if request.auth.uid == resource.data.to;
      allow update: if request.auth.uid == resource.data.to;
    }

    // A user can list chats they are a participant in.
    // A user can read/write to a chat document only if they are a participant.
    match /chats/{chatId} {
      allow list: if request.auth.uid in request.query.where.value;
      allow read, write: if request.auth.uid in resource.data.participants;

      // Messages can be read or written only by participants of the parent chat.
      match /messages/{messageId} {
        allow read, write: if get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      }
    }
  }
}
