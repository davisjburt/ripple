
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by any authenticated user, but only the user can write to their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts subcollection can only be read/written by the parent user.
      match /contacts/{contactId} {
         allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests
    match /friendRequests/{requestId} {
        // Allow user to create a request if 'from' is their own uid
        allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
        // Allow user to read if they are the recipient
        allow read: if request.auth != null && resource.data.to == request.auth.uid;
        // Allow user to update (accept/decline) if they are the recipient
        allow update: if request.auth != null && resource.data.to == request.auth.uid;
    }

    // Chat rooms and messages
    match /chats/{chatRoomId}/{messageCollection}/{messageId} {
      // A user can read/write to a chat room if their UID is in the chatRoomId
      allow read, write: if request.auth != null && request.auth.uid in chatRoomId.split('_');
    }
  }
}
