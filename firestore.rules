rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by any authenticated user, but only created if the user ID matches.
    // Writes are not allowed, profiles are updated via specific functions if needed.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update, delete: if false; // Disallow direct updates/deletes for now

      // Users can only read/write their own contacts list.
      match /contacts/{contactId} {
        allow read, list, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read if the request is addressed to the current user.
    // They can only be updated/deleted by the recipient of the request.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null;
      allow list, read: if request.auth != null && resource.data.to == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.to == request.auth.uid;
    }

    // Chat messages can be read or written only by the two participants in the chat.
    // The chat document ID must be in the format 'uid1_uid2' with UIDs sorted alphabetically.
    match /chats/{chatRoomId}/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid in chatRoomId.split('_');
    }
  }
}
