
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function
    function isSignedIn() {
      return request.auth != null;
    }

    // Users can read public profiles, but only write to their own.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;

      // A user can only manage their own contacts list.
      match /contacts/{contactId} {
        allow read, list, write, delete: if request.auth.uid == userId;
      }
    }

    // Friend requests can be created by any signed-in user.
    // They can only be read or updated (accepted/declined) by the recipient.
    match /friendRequests/{requestId} {
      allow create: if isSignedIn();
      allow read, update: if request.auth.uid == resource.data.to;
    }

    // A user can only read/write messages in chats they are a participant in.
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
    
    // Call invitations can be created by anyone.
    // Only the receiver can read/update it.
    match /callInvitations/{invitationId} {
        allow create: if isSignedIn();
        allow read, update, delete: if request.auth.uid == resource.data.receiverId;
    }

    // Call documents are accessible only by participants.
    match /calls/{callId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;

      // Signaling candidates can be created and read by participants.
      match /callerCandidates/{candidateId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
      match /receiverCandidates/{candidateId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
      }
    }
  }
}
