
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USERS
    // - Users can read their own document
    // - Anyone can read a user's public profile (for adding contacts)
    // - Only the user can create their own document
    // - Users can update their own document
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // CONTACTS Subcollection
      // - Users can only list and read their own contacts
      match /contacts/{contactId} {
        allow list, get: if isAuthenticated() && isOwner(userId);
      }
    }

    // FRIEND REQUESTS
    // - Users can create friend requests
    // - Users can only read requests sent TO them
    // - Users can update a request sent TO them (to accept/decline)
    match /friendRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.to;
    }

    // CHATS
    // - Users can list/read chat rooms they are a participant in.
    //   This rule is specifically designed to allow the `array-contains` query.
    // - Users can create new chat rooms if they are one of the participants.
    match /chats/{chatId} {
      allow list, get: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;

      // MESSAGES Subcollection
      // - Users can read and write messages in a chat they are a participant in.
      //   We get the parent chat document to check the participants list.
      match /messages/{messageId} {
        allow list, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
