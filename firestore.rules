
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user is a participant in a document
    // (Used for chats and calls)
    function isParticipant(docData) {
      return request.auth.uid in docData.participants;
    }

    // =================================
    // Users Collection
    // =================================
    match /users/{userId} {
      // Any authenticated user can read any user's profile (for searching/adding contacts)
      allow read: if isAuthenticated();
      // A user can only create their own user document
      allow create: if request.auth.uid == userId;
      // A user can only update their own profile
      allow update: if request.auth.uid == userId;
      // No one can delete user documents for now
      allow delete: if false;

      // Contacts Subcollection
      match /contacts/{contactId} {
         // A user can only read/write their own contacts list
         allow read, write: if request.auth.uid == userId;
      }
    }

    // =================================
    // Chats Collection
    // =================================
    match /chats/{chatId} {
      // Allow read/get if the user is one of the participants
      allow get: if isParticipant(resource.data);

      // Allow listing chats only if the user is a participant
      allow list: if request.auth.uid in request.query.where.participants;

      // Allow creating a chat if the user is one of the participants in the new document
      allow create: if isParticipant(request.resource.data);

      // Messages Subcollection
      match /messages/{messageId} {
        // Allow reading/writing messages if the user is a participant of the parent chat
        allow read, write: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data);
      }
    }

    // =================================
    // Friend Requests Collection
    // =================================
    match /friendRequests/{requestId} {
        // Any authenticated user can create a friend request
        allow create: if isAuthenticated();
        // Only the recipient can read or update the request (to accept/decline)
        allow read, update: if request.auth.uid == resource.data.to;
        // The creator or recipient can delete the request
        allow delete: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
    }

    // =================================
    // Call Invitations Collection
    // =================================
     match /callInvitations/{invitationId} {
        // Any authenticated user can create an invitation
        allow create: if isAuthenticated();
        // Only the recipient can read it to see if they have a call
        allow read, update, delete: if request.auth.uid == resource.data.receiverId;
     }

    // =================================
    // Calls Collection (for WebRTC)
    // =================================
    match /calls/{callId} {
        // Anyone authenticated can create a call document
        allow create: if isAuthenticated();
        
        // Only participants can read or write to the call document (for offers/answers)
        allow read, update: if isParticipant(resource.data);
        
        // Only participants can delete the call document
        allow delete: if isParticipant(get(/databases/$(database)/documents/calls/$(callId)).data);

        // ICE Candidates Subcollections
        match /{candidateCollection}/{candidateId} {
            // Only participants of the parent call can manage ICE candidates
            allow read, write, delete: if isParticipant(get(/databases/$(database)/documents/calls/$(callId)).data);
        }
    }
  }
}
