rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by anyone, but only the owner can write their own data.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Contacts subcollection is private to the user.
      match /contacts/{contactId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Friend requests can be created by any authenticated user.
    // They can only be read or updated by the sender or the recipient.
    match /friendRequests/{requestId} {
      allow read, update: if request.auth.uid == resource.data.from || request.auth.uid == resource.data.to;
      allow create: if request.auth.uid == request.resource.data.from;
    }
    
    // Chat rooms can be read or written to only by the participants.
    // The chat room ID must be a combination of the two user IDs, sorted.
    match /chats/{chatRoomId} {
      allow read, write: if request.auth.uid in chatRoomId.split('_');

      match /messages/{messageId} {
        allow read, write: if request.auth.uid in chatRoomId.split('_');
        allow create: if request.auth.uid == request.resource.data.senderId;
      }
    }
  }
}
