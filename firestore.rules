
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile.
    // Users can be looked up by email for friend requests.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null;
    }

    // Users can only read/write to their own contacts sub-collection.
    match /users/{userId}/contacts/{contactId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can create friend requests.
    // Users can read/update requests sent to or from them.
    // Users can query for requests sent TO them.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }
    
    // Users can only list/read/write chats they are a participant in.
    // This also allows ordering the chat list by the last message timestamp.
    match /chats/{chatId} {
       allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
       
       // This is the critical rule that allows fetching the chat list.
       allow list: if request.auth != null && request.query.where.path == "participants" && request.query.where.op == "array-contains" && request.query.where.value == request.auth.uid;
       
       // Users can read/write messages in chats they are a part of.
       match /messages/{messageId} {
         allow read, write: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0] == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1] == request.auth.uid;
       }
    }
  }
}
