
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null;

      match /contacts/{contactId} {
        // Allow a user to manage their own contact list
        // And allow another user to add themselves to this list
        // if they are accepting a friend request.
        allow read, write: if request.auth != null && 
                           (request.auth.uid == userId || request.auth.uid == contactId);
      }
    }
    
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.from;
      allow read: if request.auth != null && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
      allow update: if request.auth != null && request.auth.uid == resource.data.to;
      allow list: if request.auth != null;
    }

    match /chats/{chatId}/{messageId} {
      // Users can only read/write messages in chats they are part of
      // ChatId is formatted as 'userId1_userId2'
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');
    }
  }
}
