
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user is the owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if a user is a participant in a chat
    function isChatParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Users collection can be read by anyone, but only the user themselves can write to their own document.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // Contacts subcollection can only be read and written by the owner of the user document.
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Friend Requests can only be created by authenticated users.
    // They can only be read by the sender or the receiver.
    // They can only be updated (to accept/decline) by the receiver.
    match /friendRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
    }
    
    // Chats collection
    match /chats/{chatId} {
        // A user can only list chats where they are a participant.
        // This rule is critical for the main chat list page.
        allow list: if isAuthenticated() && request.query.where.get('participants').get('array-contains') == request.auth.uid;

        // A user can only get a chat document if they are a participant.
        allow get: if isChatParticipant(chatId);

        // A user can create a chat if they are one of the participants in the new document.
        allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;

        // Messages Subcollection
        match /messages/{messageId} {
            // A user can read messages if they are a participant in the parent chat.
            // This is required for fetching the "last message" in the chat list.
            allow get: if isChatParticipant(chatId);
            allow list: if isChatParticipant(chatId);

            // A user can create a message if they are a participant in the chat
            // and the message is from them.
            allow create: if isChatParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
        }
    }
  }
}
