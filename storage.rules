
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow reads of profile pictures by anyone
    match /profile-pics/{userId} {
      allow read: if true;
      // Allow writes (uploads) only by the authenticated user for their own profile picture
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
